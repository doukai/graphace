import type { GraphQLStore, QueryParams, FetchParams, Event } from "@graphace/ui-graphql";
{%- if isObjectType %}
import { fragment_{{ originalFieldTypeName }}Fields{% if isListType and isNamed %}, fragment_{{ originalFieldTypeName }}NamedFields{% endif %} } from '~/{{ storesPath }}/fragment/fragment_{{ originalFieldTypeName }}Fields';
{%- endif %}
import { createGraphQLQueryStore, fetchGraphQLQueryStore } from '~/utils';
{%- if args and args.length > 0 %}
import type { Query{{ fieldName | pascalCase }}Args } from '~/{{ schemaTypesPath }}';
{%- endif %}
{%- if isScalarType == false %}
import type { {{ fieldTypeName }} } from '~/{{ schemaTypesPath }}';
{%- endif %}

const query = ({ directives }: QueryParams) =>/* GraphQL */ `query Query_{{ fieldName }}{% if args and args.length > 0 -%}({% for arg in args %}${{ arg.inputName }}: {{ arg.inputType }}{% if forloop.last == false %}, {% endif %}{% endfor %}){% endif %} {
  {{ fieldName }}{% if args and args.length > 0 %}({% for arg in args %}{{ arg.inputName }}: ${{ arg.inputName }}{% if forloop.last == false %} {% endif %}{% endfor %}){% endif %}
  {%- if fields and fields.length > 0 %} ${directives}{
    {%- if isConnection %}
    totalCount
    edges {
      node { 
        ...{{ originalFieldTypeName }}Fields
        {%- for field in fields %}
        {%- if field.isAggregate == false %}
        {%- if field.isTable %}
        {%- if field.isNamed %}
        {{ field.fieldName }}{% if field.isListType and field.isSelect == false %}(first: 3){% endif %} {
          {{ field.fieldTypeIdName }}
          name
          description
        }
        {%- elsif field.textFieldName %}
        {{ field.fieldName }}(first: 3) {
          {{ field.fieldTypeIdName }}
          {{ field.textFieldName }}
        }
        {%- endif %}
        {%- endif %}
        {%- if field.queryOnly %}
        {%- if field.isLeafType %}
        {{ field.fieldName }}
        {%- elsif field.isFile %}
        {{ field.fieldName }} {
          id
          name
        }
        {%- elsif field.isNamed %}
        {{ field.fieldName }}{% if field.isListType and field.isSelect == false %}(first: 3){% endif %} {
          {{ field.fieldTypeIdName }}
          name
          description
        }
        {%- elsif field.textFieldName %}
        {{ field.fieldName }}(first: 3) {
          {{ field.fieldTypeIdName }}
          {{ field.textFieldName }}
        }
        {%- endif %}
        {%- endif %}
        {%- endif %}
        {%- endfor %}
      }
    }
    {%- else %}
    ...{{ originalFieldTypeName }}Fields
    {%- for field in fields %}
    {%- if field.isAggregate == false %}
    {%- if field.isTable %}
    {%- if isListType %}
    {%- if field.isNamed %}
    {{ field.fieldName }}{% if field.isListType and field.isSelect == false %}(first: 3){% endif %} {
      {{ field.fieldTypeIdName }}
      name
      description
    }
    {%- elsif field.textFieldName %}
    {{ field.fieldName }}(first: 3) {
      {{ field.fieldTypeIdName }}
      {{ field.textFieldName }}
    }
    {%- endif %}
    {%- else %}
    {{ field.fieldName }} {
      {%- for subField in field.fields %}
      {%- if subField.isAggregate == false %}
      {%- if subField.isLeafType %}
      {{ subField.fieldName }}
      {%- elsif subField.isFile %}
      {{ subField.fieldName }} {
        id
        name
      }
      {%- elsif subField.isNamed %}
      {{ subField.fieldName }}{% if subField.isListType and subField.isSelect == false %}(first: 3){% endif %} {
        {{ subField.fieldTypeIdName }}
        name
        description
      }
      {%- elsif subField.textFieldName %}
      {{ subField.fieldName }}(first: 3) {
        {{ subField.fieldTypeIdName }}
        {{ subField.textFieldName }}
      }
      {%- endif %}
      {%- endif %}
      {%- endfor %}
    }
    {%- endif %}
    {%- endif %}
    {%- if field.queryOnly %}
    {%- if field.isLeafType %}
    {{ field.fieldName }}
    {%- elsif field.isFile %}
    {{ field.fieldName }} {
      id
      name
    }
    {%- elsif field.isNamed %}
    {{ field.fieldName }}{% if field.isListType and field.isSelect == false %}(first: 3){% endif %} {
      {{ field.fieldTypeIdName }}
      name
      description
    }
    {%- elsif field.textFieldName %}
    {{ field.fieldName }}(first: 3) {
      {{ field.fieldTypeIdName }}
      {{ field.textFieldName }}
    }
    {%- endif %}
    {%- endif %}
    {%- endif %}
    {%- endfor %}
    {%- endif %}
  }
  {%- endif %}
}
{%- if isObjectType %}
${fragment_{{ originalFieldTypeName }}Fields}
{%- endif %}`;

export function createQuery_{{ fieldName }}_Store(event: Event): Query_{{ fieldName }}_Store {
  return createGraphQLQueryStore<{ {{ fieldName }}: {{ tsTypeName }}{% if isListType %}[]{% endif %} }, {% if args and args.length > 0 %}Query{{ fieldName | pascalCase }}Args{% else %}undefined{% endif %}>(query, event);
}

export async function fetchQuery_{{ fieldName }}_Store(event: Event, variables{% if args == undefined or args.length == 0 %}?{% endif %}: {% if args and args.length > 0 %}Query{{ fieldName | pascalCase }}Args{% else %}undefined{% endif %}): Promise<Query_{{ fieldName }}_Store> {
  return fetchGraphQLQueryStore<{ {{ fieldName }}: {{ tsTypeName }}{% if isListType %}[]{% endif %} }, {% if args and args.length > 0 %}Query{{ fieldName | pascalCase }}Args{% else %}undefined{% endif %}>(query, event, variables);
}

export type Query_{{ fieldName }}_Store = GraphQLStore<{ {{ fieldName }}: {{ tsTypeName }}{% if isListType %}[]{% endif %} }, {% if args and args.length > 0 %}Query{{ fieldName | pascalCase }}Args{% else %}undefined{% endif %}>;
{%- if isListType and isNamed %}

const queryNamed = ({ directives }: QueryParams) =>/* GraphQL */ `query QueryNamed_{{ fieldName }}{% if args and args.length > 0 -%}({% for arg in args %}${{ arg.inputName }}: {{ arg.inputType }}{% if forloop.last == false %}, {% endif %}{% endfor %}){% endif %} {
  {{ fieldName }}{% if args and args.length > 0 %}({% for arg in args %}{{ arg.inputName }}: ${{ arg.inputName }}{% if forloop.last == false %} {% endif %}{% endfor %}){% endif %} ${directives}{
    ...{{ originalFieldTypeName }}NamedFields
  }
}
${fragment_{{ originalFieldTypeName }}NamedFields}`;

export function createQueryNamed_{{ fieldName }}_Store(event: Event): QueryNamed_{{ fieldName }}_Store {
  return createGraphQLQueryStore<{ {{ fieldName }}: {{ tsTypeName }}{% if isListType %}[]{% endif %} }, {% if args and args.length > 0 %}Query{{ fieldName | pascalCase }}Args{% else %}undefined{% endif %}>(queryNamed, event);
}

export async function fetchQueryNamed_{{ fieldName }}_Store(event: Event, variables{% if args == undefined or args.length == 0 %}?{% endif %}: {% if args and args.length > 0 %}Query{{ fieldName | pascalCase }}Args{% else %}undefined{% endif %}, params?: FetchParams | undefined): Promise<QueryNamed_{{ fieldName }}_Store> {
  return fetchGraphQLQueryStore<{ {{ fieldName }}: {{ tsTypeName }}{% if isListType %}[]{% endif %} }, {% if args and args.length > 0 %}Query{{ fieldName | pascalCase }}Args{% else %}undefined{% endif %}>(queryNamed, event, variables, params);
}

export type QueryNamed_{{ fieldName }}_Store = GraphQLStore<{ {{ fieldName }}: {{ tsTypeName }}{% if isListType %}[]{% endif %} }, {% if args and args.length > 0 %}Query{{ fieldName | pascalCase }}Args{% else %}undefined{% endif %}>;
{%- endif %}