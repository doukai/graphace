export const fragment_{{ name }}Fields = /* GraphQL */ `fragment {{ name }}Fields on {{ name }} {
    {%- if fields and fields.length > 0 %}
    {%- for field in fields %}
    {%- if field.isAggregate == false %}
    {%- if field.isLeafType %}
    {{ field.fieldName }}
    {%- elsif field.isFile %}
    {{ field.fieldName }} {
      id
      name
    }
    {%- elsif field.isTable == false %}
    {%- if field.isNamed %}
    {{ field.fieldName }}{% if field.isListType and field.isSelect == false %}(first: 3){% endif %} {
      {{ field.fieldTypeIdName }}
      name
      description
    }
    {%- elsif field.textFieldName %}
    {{ field.fieldName }}(first: 3) {
      {{ field.fieldTypeIdName }}
      {{ field.textFieldName }}
    }
    {%- endif %}
    {%- endif %}
    {%- endif %}
    {%- endfor %}
    {%- endif %}
  }`;
{%- if isNamed %}

export const fragment_{{ name }}NamedFields = /* GraphQL */ `fragment {{ name }}NamedFields on {{ name }} {
    id
    name
    description
  }`;
{%- endif %}