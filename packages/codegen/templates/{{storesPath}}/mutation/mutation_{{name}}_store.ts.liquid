import type { GraphQLStore, QueryParams, Event } from "@graphace/ui-graphql";
{%- if isObjectType %}
import { fragment_{{ fieldTypeName }}Fields } from '~/{{ storesPath }}/fragment/fragment_{{ fieldTypeName }}Fields';
{%- endif %}
import { createGraphQLMutationStore } from '~/utils';
{%- if args and args.length > 0 %}
import type { Mutation{{ fieldName | pascalCase }}Args } from '~/{{ schemaTypesPath }}';
{%- endif %}
{%- if isScalarType == false %}
import type { {{ fieldTypeName }} } from '~/{{ schemaTypesPath }}';
{%- endif %}

const query = ({ directives }: QueryParams) =>/* GraphQL */ `mutation Mutation_{{ fieldName }}{% if args and args.length > 0 -%}({% for arg in args %}${{ arg.inputName }}: {{ arg.inputType }}{% if forloop.last == false %}, {% endif %}{% endfor %}){% endif %} {
  {{ fieldName }}{% if args and args.length > 0 %}({% for arg in args %}{{ arg.inputName }}: ${{ arg.inputName }}{% if forloop.last == false %} {% endif %}{% endfor %}){% endif %}
    {%- if fields and fields.length > 0 %} ${directives}{
    ...{{ fieldTypeName }}Fields
    {%- for field in fields %}
    {%- if field.isAggregate == false %}
    {%- if field.isTable %}
    {%- if isListType %}
    {%- if field.isNamed %}
    {{ field.fieldName }}{% if field.isListType and field.isSelect == false %}(first: 3){% endif %} {
      {{ field.fieldTypeIdName }}
      name
      description
    }
    {%- elsif field.textFieldName %}
    {{ field.fieldName }}(first: 3) {
      {{ field.fieldTypeIdName }}
      {{ field.textFieldName }}
    }
    {%- endif %}
    {%- else %}
    {{ field.fieldName }} {
      {%- for subField in field.fields %}
      {%- if subField.isAggregate == false %}
      {%- if subField.isLeafType %}
      {{ subField.fieldName }}
      {%- elsif subField.isFile %}
      {{ subField.fieldName }} {
        id
        name
      }
      {%- elsif subField.isNamed %}
      {{ subField.fieldName }}{% if subField.isListType and subField.isSelect == false %}(first: 3){% endif %} {
        {{ subField.fieldTypeIdName }}
        name
        description
      }
      {%- elsif subField.textFieldName %}
      {{ subField.fieldName }}(first: 3) {
        {{ subField.fieldTypeIdName }}
        {{ subField.textFieldName }}
      }
      {%- endif %}
      {%- endif %}
      {%- endfor %}
    }
    {%- endif %}
    {%- if field.mutationOnly %}
    {%- if field.isLeafType %}
    {{ field.fieldName }}
    {%- elsif field.isFile %}
    {{ field.fieldName }} {
      id
      name
    }
    {%- elsif field.isNamed %}
    {{ field.fieldName }}{% if field.isListType and field.isSelect == false %}(first: 3){% endif %} {
      {{ field.fieldTypeIdName }}
      name
      description
    }
    {%- elsif field.textFieldName %}
    {{ field.fieldName }}(first: 3) {
      {{ field.fieldTypeIdName }}
      {{ field.textFieldName }}
    }
    {%- endif %}
    {%- endif %}
    {%- endif %}
    {%- endif %}
    {%- endfor %}
  }
  {%- endif %}
}
{%- if isObjectType %}
${fragment_{{ fieldTypeName }}Fields}
{%- endif %}`;

export function createMutation_{{ fieldName }}_Store(event: Event): Mutation_{{ fieldName }}_Store {
  return createGraphQLMutationStore<{ {{ fieldName }}: {{ tsTypeName }}{% if isListType %}[]{% endif %} }, {% if args and args.length > 0 %}Mutation{{ fieldName | pascalCase }}Args{% else %}undefined{% endif %}>(query, event);
}

export type Mutation_{{ fieldName }}_Store = GraphQLStore<{ {{ fieldName }}: {{ tsTypeName }}{% if isListType %}[]{% endif %} }, {% if args and args.length > 0 %}Mutation{{ fieldName | pascalCase }}Args{% else %}undefined{% endif %}>;