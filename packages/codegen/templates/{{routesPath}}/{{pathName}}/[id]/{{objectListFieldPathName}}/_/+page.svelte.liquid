<script lang="ts">
	import type { Errors } from '@graphace/commons';
	import { ot, to, canBack, Card, CardBody, Breadcrumbs, toast, modal } from '@graphace/ui';
	import {{ fieldObjectInfo.name }}Form from '~/{{ componentsPath }}/objects/{{ fieldObjectInfo.name | paramCase }}/{{ fieldObjectInfo.name }}Form.svelte';
	import {
		validator,
		{%- if useAuth %}
		permissions,
		{%- endif %}
		buildGlobalGraphQLErrorMessage,
		buildGraphQLErrors
	} from '~/utils';
	import type { {{ fieldObjectInfo.name }}Input } from '~/{{ schemaTypesPath }}';
	import { LL, locale } from '$i18n/i18n-svelte';
	import type { PageData } from './$types';

	export let data: PageData;

	const { validate } = validator;
	{%- if useAuth %}
	const { auth } = permissions;
	{%- endif %}

	$: id = data.{{ idName }};
	$: mutation_{{ name | camelCase }}_{{ fieldInfo.fieldName }}_Store = data.mutation_{{ name | camelCase }}_{{ fieldInfo.fieldName }}_Store;
	{%- if hasFileField %}
	$: mutation_singleUpload_Store = data.mutation_singleUpload_Store;
	{%- endif %}

	let value: {{ fieldObjectInfo.name }}Input = {};
	let errors: Record<string, Errors> = {};

	const merge = (input: {{ fieldObjectInfo.name }}Input) => {
		validate('{{ mutationTypeName }}_{{ name | camelCase }}_Arguments', { where: { {{ idName }}: { val: id } }, {{ fieldInfo.fieldName }}: [input] })
			.then((data) => {
				errors = {};
				mutation_{{ name | camelCase }}_{{ fieldInfo.fieldName }}_Store
					.fetch({
						{{ name | camelCase }}_{{ idName }}: {{ idName }},
						{{ name | camelCase }}_{{ fieldInfo.fieldName }}: [input]
					})
					.then((result) => {
						if (result.errors) {
							console.error(result.errors);
							errors = buildGraphQLErrors(result.errors, data);
							const globalError = buildGlobalGraphQLErrorMessage(result.errors);
							if (globalError) {
								modal.open({
									title: $LL.{{ appName }}.message.requestFailed(),
									description: globalError
								});
							}
						} else {
							toast.success($LL.{{ appName }}.message.requestSuccess());
							ot();
						}
					});
			})
			.catch((validErrors) => {
				console.error(validErrors);
				errors = validErrors.{{ fieldInfo.fieldName }}?.iterms[0]?.iterms;
			});
	};
</script>

<Breadcrumbs>
	<li>
		<a href={undefined} on:click|preventDefault={(e) => to(`/${$locale}/{{ name | paramCase }}`)}>
			<span class="badge badge-outline">{$LL.graphql.objects.{{ name }}.name()}</span>
		</a>
	</li>
	<li>
		<a href={undefined} on:click|preventDefault={(e) => to(`/${$locale}/{{ name | paramCase }}/${% raw %}{{% endraw %}{{ idName }}{% raw %}}{% endraw %}`)}>
			<span class="badge badge-outline">{$LL.{{ appName }}.path.edit({ name: $LL.graphql.objects.{{ name }}.name() })}</span>
		</a>
	</li>
	<li>
		<a href={undefined} on:click|preventDefault={(e) => to(`/${$locale}/{{ name | paramCase }}/${% raw %}{{% endraw %}{{ idName }}{% raw %}}{% endraw %}/{{ fieldInfo.fieldName | paramCase }}`)}>
			<span class="badge badge-outline">{$LL.graphql.objects.{{ name }}.fields.{{ fieldInfo.fieldName }}.name()}</span>
		</a>
	</li>
	<li>
		<span class="badge badge-neutral">{$LL.{{ appName }}.path.create({ name: $LL.graphql.objects.{{ fieldObjectInfo.name }}.name() })}</span>
	</li>
</Breadcrumbs>
<Card class="flex flex-col max-w-full min-h-0">
	<CardBody class="flex-1 min-h-0 overflow-auto">
		<{{ fieldObjectInfo.name }}Form
			showSaveButton={auth('{{ fieldObjectInfo.name }}::*::WRITE')}
			showBackButton={$canBack}
			bind:value
			{errors}
			isMutating={$validator.isValidating || $mutation_{{ name | camelCase }}_{{ fieldInfo.fieldName }}_Store.isFetching}
			on:save={(e) => {
				if (e.detail.value) {
					merge(e.detail.value);
				}
			{% raw %}}}{% endraw %}
			on:back={(e) => ot()}
			{%- if hasFileField %}
			on:upload={(e) => {
				mutation_singleUpload_Store.fetch({ file: e.detail.file }).then((result) =>
					e.detail.then(result.data?.singleUpload)
				);
			{% raw %}}}{% endraw %}
			{%- endif %}
		/>
	</CardBody>
</Card>
