		{%- elsif field.isFile %}
		'file-input'?: {} | undefined;
		{%- elsif field.isEnumType %}
		'select'?: {} | undefined;
		{%- else %}
		'table'?: {} | undefined;
		'form'?: {} | undefined;
		'combobox'?: {} | undefined;
		'dialog'?: {} | undefined;
		'link'?: {} | undefined;
		{%- endif %}
	} | undefined;
	{%- endfor %}
