export type {{ name }}Fields = {
	{%- for field in fields %}
	{%- if field.isListType %}
	{{ field.fieldName }}?: Option<TranslationFunctions, {{ name }}Input, Query{{ name }}ListArgs, ({% if field.isObjectType %}{{ field.fieldTypeName }}Input{% elsif field.isEnumType %}{{ field.fieldTypeName }}{% else %}{{ field.tsTypeName }}{% endif %} | null | undefined)[] | null | undefined, {{ name }}FieldsArgs['{{ field.fieldName }}'], {{ name }}FieldsProps['{{ field.fieldName }}'], {% if field.isObjectType %}{{ field.fieldTypeName }}Fields{% else %}{}{% endif %}> | undefined;
	{%- else %}
	{{ field.fieldName }}?: Option<TranslationFunctions, {{ name }}Input, Query{{ name }}ListArgs, {% if field.isObjectType %}{{ field.fieldTypeName }}Input{% elsif field.isEnumType %}{{ field.fieldTypeName }}{% else %}{{ field.tsTypeName }}{% endif %} | null | undefined, {{ name }}FieldsArgs['{{ field.fieldName }}'], {{ name }}FieldsProps['{{ field.fieldName }}'], {% if field.isObjectType %}{{ field.fieldTypeName }}Fields{% else %}{}{% endif %}> | undefined;
	{%- endif %}
	{%- endfor %}
};

export const {{ name | camelCase }}Fields: {{ name }}Fields = {
	{%- for field in fields %}
	{{ field.fieldName }}: {
		readonly: (value, fieldArg) => {
			return {% if useAuth %}!auth('{{ name }}::{{ field.fieldName }}::WRITE'){% else %}false{% endif %};
		},
		disabled: (value, fieldArg) => {
			return {% if useAuth %}!auth('{{ name }}::{{ field.fieldName }}::WRITE'){% else %}false{% endif %};
		},
		hidden: (value, tab, fieldArg) => {
			return {% if useAuth %}!auth('{{ name }}::{{ field.fieldName }}::READ'){% else %}false{% endif %};
		},
		hiddenCol: (args, tab, fieldArg) => {
			return {% if useAuth %}!auth('{{ name }}::{{ field.fieldName }}::READ'){% else %}false{% endif %};
		},
		hiddenFilter: (args, fieldArg) => {
			return {% if useAuth %}!auth('{{ name }}::{{ field.fieldName }}::READ'){% else %}false{% endif %};
		},
		required: (value) => {
			return {% if field.isNonNullType %}true{% else %}false{% endif %};
		},
		validate: async ($LL, value) => {
			return [];
		},
		onChange: async ($LL, fieldValue, value, fieldArg) => {
			return value;
		},
		props: ($LL, value, fieldArg) => {
			return {};
		},
		title: ($LL, fieldArg) => {
			return $LL.graphql.objects.{{ name }}.fields.{{ field.fieldName }}.name();
		},
		fromRecord: ($LL, fields, title, record, fieldArg) => {
			{%- if field.isObjectType %}
			{%- if field.isListType %}
			return objectListFromRecord($LL, fields, title, record, fieldArg);
			{%- else %}
			return objectFromRecord($LL, fields, title, record, fieldArg);
			{%- endif %}
			{%- else %}
			{%- if field.isListType %}
			{%- if field.fieldTypeName == 'Boolean' %}
			return booleanListFromRecord(record, title, '/', $LL.{{ appName }}.components.label.true());
			{%- elsif field.fieldTypeName == 'Int' or field.fieldTypeName == 'BigInteger' %}
			return numberListFromRecord(record, title, '/');
			{%- elsif field.fieldTypeName == 'Float' or field.fieldTypeName == 'BigDecimal' %}
			return floatListFromRecord(record, title, '/');
			{%- elsif field.isScalarType %}
			return stringListFromRecord(record, title, '/');
			{%- elsif field.isEnumType %}
			return enumListFromRecord(record, title, '/', $LL.graphql.enums.{{ field.fieldTypeName }}.values);
			{%- endif %}
			{%- else %}
			{%- if field.fieldTypeName == 'Boolean' %}
			return booleanFromRecord(record, title, $LL.{{ appName }}.components.label.true());
			{%- elsif field.fieldTypeName == 'DateTime' or field.fieldTypeName == 'Timestamp' %}
			return dateTimeFromRecord(record, title);
			{%- elsif field.fieldTypeName == 'Date' %}
			return dateFromRecord(record, title);
			{%- elsif field.fieldTypeName == 'Int' or field.fieldTypeName == 'BigInteger' %}
			return numberFromRecord(record, title);
			{%- elsif field.fieldTypeName == 'Float' or field.fieldTypeName == 'BigDecimal' %}
			return floatFromRecord(record, title);
			{%- elsif field.isScalarType %}
			return stringFromRecord(record, title);
			{%- elsif field.isEnumType %}
			return enumFromRecord(record, title, $LL.graphql.enums.{{ field.fieldTypeName }}.values);
			{%- endif %}
			{%- endif %}
			{%- endif %}
		}{%- if field.isObjectType%},
		toFields: (fieldArg) => {
			{%- if field.isNamed %}
			const { name } = {{ field.fieldTypeName | camelCase }}Fields;
			return { name };
			{%- elsif field.textFieldName %}
			const { {{ field.textFieldName }} } = {{ field.fieldTypeName | camelCase }}Fields;
			return { {{ field.textFieldName }} };
			{%- else %}
			return {};
			{%- endif %}
		},
		toRecord: ($LL, fields, title, value, fieldArg) => {
			{%- if field.isListType %}
			return objectListToRecord($LL, fields, title, value, '{{ field.fieldName }}', fieldArg);
			{%- else %}
			return objectToRecord($LL, fields, title, value, '{{ field.fieldName }}', fieldArg);
			{%- endif %}
		},
		fields: (value, fieldArg) => {{ field.fieldTypeName | camelCase }}Fields
		{%- else %},
		toString: ($LL, value, fieldArg) => {
			{%- if field.isListType %}
			{%- if field.fieldTypeName == 'Boolean' %}
			return booleanListToString(value, '{{ field.fieldName }}', '/', $LL.{{ appName }}.components.label.true(), $LL.{{ appName }}.components.label.false());
			{%- elsif field.fieldTypeName == 'Int' or field.fieldTypeName == 'BigInteger' %}
			return numberListToString(value, '{{ field.fieldName }}', '/');
			{%- elsif field.fieldTypeName == 'Float' or field.fieldTypeName == 'BigDecimal' %}
			return floatListToString(value, '{{ field.fieldName }}', '/');
			{%- elsif field.isScalarType %}
			return stringListToString(value, '{{ field.fieldName }}', '/');
			{%- elsif field.isEnumType %}
			return enumListToString(value, '{{ field.fieldName }}', '/', $LL.graphql.enums.{{ field.fieldTypeName }}.values);
			{%- endif %}
			{%- else %}
			{%- if field.fieldTypeName == 'Boolean' %}
			return booleanToString(value, '{{ field.fieldName }}', $LL.{{ appName }}.components.label.true(), $LL.{{ appName }}.components.label.false());
			{%- elsif field.fieldTypeName == 'Int' or field.fieldTypeName == 'BigInteger' %}
			return numberToString(value, '{{ field.fieldName }}');
			{%- elsif field.fieldTypeName == 'Float' or field.fieldTypeName == 'BigDecimal' %}
			return floatToString(value, '{{ field.fieldName }}');
			{%- elsif field.isScalarType %}
			return stringToString(value, '{{ field.fieldName }}');
			{%- elsif field.isEnumType %}
			return enumToString(value, '{{ field.fieldName }}', $LL.graphql.enums.{{ field.fieldTypeName }}.values);
			{%- endif %}
			{%- endif %}
		}
		{%- endif %}
	}{% if forloop.last == false %},{% endif %}
	{%- endfor %}
};

