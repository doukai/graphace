import { format } from 'date-fns';
import type { Errors } from '@graphace/commons';
import type { TabInfo } from '@graphace/ui';
import type { Option } from '@graphace/ui-graphql';
{%- for object in objects %}
{%- if object != name %}
import { {{ object | camelCase }}Fields, type {{ object }}Fields } from '~/{{ componentsPath }}/objects/{{ object | paramCase }}/{{ object }}Option';
{%- endif %}
{%- endfor %}
import type {
	{{ name }}Input,
	Query{{ name }}Args,
	Query{{ name }}ListArgs
{%- for object in objects %}
{%- if object != name %},
	{{ object }}Input
{%- endif %}
{%- endfor %}
{%- for enum in enums %},
	{{ enum }}
{%- endfor %}
} from '~/{{ schemaTypesPath }}';
import type { TranslationFunctions } from '$i18n/i18n-types';
{%- if useAuth %}
import { permissions } from '~/utils';
{%- endif %}

{%- if useAuth %}
const { auth } = permissions;
{%- endif %}

export const {{ name | camelCase }}Init: ((value: {{ name }}Input | null | undefined) => {{ name }}Input | null | undefined) | undefined = undefined;

export const {{ name | camelCase }}Tabs: (($LL: TranslationFunctions, args?: Query{{ name }}ListArgs | undefined) => TabInfo[] | undefined) | undefined = undefined;

export const {{ name | camelCase }}Tab: ((args?: Query{{ name }}ListArgs | undefined) => string | undefined) | undefined = undefined;

export const {{ name | camelCase }}TabChange = async (tab: string, args: Query{{ name }}ListArgs, value?: ({{ name }}Input | null | undefined)[] | null | undefined) => {
	return new Promise(
		(
			resolve: (data: Query{{ name }}ListArgs) => void,
			reject: (errors: Record<number, Errors>) => void
		) => {
			resolve(args);
		}
	);
};

export const {{ name | camelCase }}FormTabs: (($LL: TranslationFunctions, args?: Query{{ name }}Args | undefined) => TabInfo[] | undefined) | undefined = undefined;

export const {{ name | camelCase }}FormTab: ((args?: Query{{ name }}Args | undefined) => string | undefined) | undefined = undefined;

export const {{ name | camelCase }}FormTabChange = async (tab: string, args: Query{{ name }}Args, value?: {{ name }}Input | null | undefined) => {
	return new Promise(
		(
			resolve: (data: Query{{ name }}Args) => void,
			reject: (errors: Record<string, Errors>) => void
		) => {
			resolve(args);
		}
	);
};

export type {{ name }}FieldsArgs = {
	{%- for field in fields %}
	{{ field.fieldName }}?: {} | undefined;
	{%- endfor %}
};

export type {{ name }}FieldsProps = {
	{%- for field in fields %}
	{{ field.fieldName }}?: {
		'tr'?: {} | undefined;
		'th'?: {} | undefined;
		'td'?: {} | undefined;
		'form-control'?: {} | undefined;
		{%- if field.isObjectType %}
		'table'?: {} | undefined;
		'form'?: {} | undefined;
		'combobox'?: {} | undefined;
		'dialog'?: {} | undefined;
		'link'?: {} | undefined;
		{%- else %}
		'input'?: {} | undefined;
		'select'?: {} | undefined;
		{%- endif %}
	} | undefined;
	{%- endfor %}
};

export type {{ name }}Fields = {
	{%- for field in fields %}
	{%- if field.isListType %}
	{{ field.fieldName }}?: Option<TranslationFunctions, {{ name }}Input, Query{{ name }}ListArgs, ({% if field.isObjectType %}{{ field.fieldTypeName }}Input{% elsif field.isEnumType %}{{ field.fieldTypeName }}{% else %}{{ field.tsTypeName }}{% endif %} | null | undefined)[] | null | undefined, {{ name }}FieldsArgs['{{ field.fieldName }}'], {{ name }}FieldsProps['{{ field.fieldName }}'], {% if field.isObjectType %}{{ field.fieldTypeName }}Fields{% else %}{}{% endif %}> | undefined;
	{%- else %}
	{{ field.fieldName }}?: Option<TranslationFunctions, {{ name }}Input, Query{{ name }}ListArgs, {% if field.isObjectType %}{{ field.fieldTypeName }}Input{% elsif field.isEnumType %}{{ field.fieldTypeName }}{% else %}{{ field.tsTypeName }}{% endif %} | null | undefined, {{ name }}FieldsArgs['{{ field.fieldName }}'], {{ name }}FieldsProps['{{ field.fieldName }}'], {% if field.isObjectType %}{{ field.fieldTypeName }}Fields{% else %}{}{% endif %}> | undefined;
	{%- endif %}
	{%- endfor %}
};

export const {{ name | camelCase }}Fields: {{ name }}Fields = {
	{%- for field in fields %}
	{{ field.fieldName }}: {
		readonly: (value, fieldArg) => {
			return {% if useAuth %}!auth('{{ name }}::{{ field.fieldName }}::WRITE'){% else %}false{% endif %};
		},
		disabled: (value, fieldArg) => {
			return {% if useAuth %}!auth('{{ name }}::{{ field.fieldName }}::WRITE'){% else %}false{% endif %};
		},
		hidden: (value, tab, fieldArg) => {
			return {% if useAuth %}!auth('{{ name }}::{{ field.fieldName }}::READ'){% else %}false{% endif %};
		},
		hiddenCol: (args, tab, fieldArg) => {
			return {% if useAuth %}!auth('{{ name }}::{{ field.fieldName }}::READ'){% else %}false{% endif %};
		},
		required: (value) => {
			return {% if field.isNonNullType %}true{% else %}false{% endif %};
		},
		validate: async ($LL, value) => {
			return [];
		},
		onChange: async ($LL, fieldValue, value, fieldArg) => {
			return new Promise(
				(
					resolve: (data: {{ name }}Input | null | undefined) => void,
					reject: (errors: Errors) => void
				) => {
					resolve(value);
				}
			);
		},
		props: ($LL, value, fieldArg) => {
			return {};
		},
		title: ($LL, fieldArg) => {
			return $LL.graphql.objects.{{ name }}.fields.{{ field.fieldName }}.name();
		},
		fromRecord: ($LL, fields, title, record, fieldArg) => {
			{%- if field.isObjectType %}
			if (fields) {
				{%- if field.isListType %}
				const fieldStringArray = Object.fromEntries(
					Object.entries(fields)
						.flatMap(([fieldName, option]) => {
							const string = record?.[title + '-' + (option?.title?.($LL, fieldArg) || fieldName)];
							if (string?.includes('|')) {
								return [[fieldName, string?.split('|')]];
							} else if (string) {
								return [[fieldName, [string]]];
							}
							return [];
						})
				);

				const fieldRecords = Array.from({ length: Object.values(fieldStringArray)[0]?.length || 0 })
					.map((_, row) =>
						Object.fromEntries(
							Object.entries(fieldStringArray)
								.map(([fieldName, stringArray]) =>
									[fieldName, stringArray[row]]
								)
						)
					);

				const value = fieldRecords.map(fieldRecord =>
					Object.fromEntries(
						Object.entries(fields)
							.flatMap(([fieldName, option]) => {
								const fields = option.toFields?.();
								const value = option.fromRecord?.($LL, fields, fieldName, fieldRecord);
								if (value) {
									return [[fieldName, value]];
								}
								return [];
							})
					) as {{ field.fieldTypeName }}Input | null | undefined
				);

				if (value.length) {
					return value;
				}
				{%- else %}
				const fieldRecord = Object.fromEntries(
					Object.entries(fields)
						.flatMap(([fieldName, option]) => {
							const string = record?.[title + '-' + (option?.title?.($LL, fieldArg) || fieldName)];
							if (string) {
								return [[fieldName, string]];
							}
							return [];
						})
				);

				const value = Object.fromEntries(
					Object.entries(fields)
						.flatMap(([fieldName, option]) => {
							const fields = option.toFields?.();
							const value = option.fromRecord?.($LL, fields, fieldName, fieldRecord);
							if (value) {
								return [[fieldName, value]];
							}
							return [];
						})
				) as {{ field.fieldTypeName }}Input;

				if (Object.keys(value).length) {
					return value;
				}
				{%- endif %}
			}
			{%- else %}
			const string = record?.[title];
			if (string != null) {
				{%- if field.isListType %}
				{%- if field.fieldTypeName == 'Boolean' %}
				if (string.includes('/')) {
					return string.split('/').map(item => item === $LL.{{ appName }}.components.label.true() ? true : false);
				} else {
					return [string === $LL.{{ appName }}.components.label.true() ? true : false]
				}
				{%- elsif field.fieldTypeName == 'Int' or field.fieldTypeName == 'BigInteger' %}
				if (string.includes('/')) {
					return string.split('/').map(item => parseInt(item));
				} else {
					return [parseInt(string)];
				}
				{%- elsif field.fieldTypeName == 'Float' or field.fieldTypeName == 'BigDecimal' %}
				if (string.includes('/')) {
					return string.split('/').map(item => parseFloat(item));
				} else {
					return [parseFloat(string)];
				}
				{%- elsif field.isScalarType %}
				if (string.includes('/')) {
					return string.split('/');
				} else {
					return [string];
				}
				{%- elsif field.isEnumType %}
				if (string.includes('/')) {
					return string.split('/').map(item => Object.entries($LL.graphql.enums.{{ field.fieldTypeName }}.values).find(([_, v]) => v.name() === item)?.[0] as {{ field.fieldTypeName }});
				} else {
					return [Object.entries($LL.graphql.enums.{{ field.fieldTypeName }}.values).find(([_, v]) => v.name() === string)?.[0] as {{ field.fieldTypeName }}];
				}
				{%- endif %}
				{%- else %}
				{%- if field.fieldTypeName == 'Boolean' %}
				return string === $LL.{{ appName }}.components.label.true() ? true : false;
				{%- elsif field.fieldTypeName == 'DateTime' or field.fieldTypeName == 'Timestamp' %}
				if (typeof string !== "number") {
					return string;
				} else if (string >= 25569) {
					const date = new Date((string - 25569) * 86400000);
					return format(date, "yyyy-MM-dd HH:mm:ss");
				}
				{%- elsif field.fieldTypeName == 'Date' %}
				if (typeof string !== "number") {
					return string;
				} else if (string >= 25569) {
					const date = new Date((string - 25569) * 86400000);
					return format(date, "yyyy-MM-dd");
				}
				{%- elsif field.fieldTypeName == 'Int' or field.fieldTypeName == 'BigInteger' %}
				return parseInt(string);
				{%- elsif field.fieldTypeName == 'Float' or field.fieldTypeName == 'BigDecimal' %}
				return parseFloat(string);
				{%- elsif field.isScalarType %}
				return string;
				{%- elsif field.isEnumType %}
				return Object.entries($LL.graphql.enums.{{ field.fieldTypeName }}.values).find(([_, v]) => v.name() === string)?.[0] as {{ field.fieldTypeName }};
				{%- endif %}
				{%- endif %}
			}
			{%- endif %}
			return undefined;
		}{%- if field.isObjectType%},
		toFields: (fieldArg) => {
			{%- if field.isNamed %}
			const { name } = {{ field.fieldTypeName | camelCase }}Fields;
			return { name };
			{%- elsif field.textFieldName %}
			const { {{ field.textFieldName }} } = {{ field.fieldTypeName | camelCase }}Fields;
			return { {{ field.textFieldName }} };
			{%- else %}
			return {};
			{%- endif %}
		},
		toRecord: ($LL, fields, title, value, fieldArg) => {
			const fieldValue = value?.{{ field.fieldName }};
			{%- if field.isListType %}
			return Object.fromEntries(
				Object.entries(fields)
					.map(([fieldName, option]) =>
						[
							[title + '-' + (option?.title?.($LL, fieldArg) || fieldName)],
							fieldValue?.map(item => option?.toString?.($LL, item, fieldArg) || '').join('|') || ''
						]
					)
			);
			{%- else %}
			return Object.fromEntries(
				Object.entries(fields)
					.map(([fieldName, option]) =>
						[
							[title + '-' + (option?.title?.($LL, fieldArg) || fieldName)],
							option?.toString?.($LL, fieldValue, fieldArg) || ''
						]
					)
			);
			{%- endif %}
		},
		fields: (value, fieldArg) => {{ field.fieldTypeName | camelCase }}Fields
		{%- else %},
		toString: ($LL, value, fieldArg) => {
			const fieldValue = value?.{{ field.fieldName }};
			if (fieldValue != null) {
				{%- if field.isListType %}
				{%- if field.fieldTypeName == 'Boolean' %}
				return fieldValue.map(item => item ? $LL.{{ appName }}.components.label.true() : $LL.{{ appName }}.components.label.false()).join('/');
				{%- elsif field.isScalarType %}
				return fieldValue.map(item => item != null ? item.toString() : '').join('/');
				{%- elsif field.isEnumType %}
				return fieldValue.map(item => $LL.graphql.enums.{{ field.fieldTypeName }}.values[fieldValue].name()).join('/');
				{%- endif %}
				{%- else %}
				{%- if field.fieldTypeName == 'Boolean' %}
				return fieldValue ? $LL.{{ appName }}.components.label.true() : $LL.{{ appName }}.components.label.false();
				{%- elsif field.isScalarType %}
				return fieldValue.toString();
				{%- elsif field.isEnumType %}
				return $LL.graphql.enums.{{ field.fieldTypeName }}.values[fieldValue].name();
				{%- endif %}
				{%- endif %}
			}
			return '';
		}
		{%- endif %}
	}{% if forloop.last == false %},{% endif %}
	{%- endfor %}
};

export const validateRequired = async ($LL: TranslationFunctions, value: {{ name }}Input | null | undefined) => {
	const errors: Record<string, Errors> = {};
	if (value) {
		for (const [fieldName, options] of Object.entries({{ name | camelCase }}Fields)) {
			if (options?.required?.(value) && value[fieldName as keyof {{ name }}Input] == null) {
				errors[fieldName] = { errors: [{ message: $LL.errors.jsonSchema.required() }] };
			}
		}
	}
	return errors;
};

export const validateErrors = async ($LL: TranslationFunctions, value: {{ name }}Input | null | undefined) => {
	const errors: Record<string, Errors> = {};
	if (value) {
		for (const [fieldName, options] of Object.entries({{ name | camelCase }}Fields)) {
			const fieldErrors = await options?.validate?.($LL, value);
			if (fieldErrors && fieldErrors.length > 0) {
				errors[fieldName] = { errors: fieldErrors.map((message) => ({ message })) };
			}
		}
	}
	return errors;
};

export const validate = async ($LL: TranslationFunctions, value: {{ name }}Input | null | undefined) => {
	let errors = await validateRequired($LL, value);
	if (Object.keys(errors).length === 0) {
		errors = await validateErrors($LL, value);
	}
	return new Promise(
		(
			resolve: (data: {{ name }}Input | null | undefined) => void,
			reject: (errors: Record<string, Errors>) => void
		) => {
			if (Object.keys(errors).length === 0) {
				resolve(value);
			} else {
				reject(errors);
			}
		}
	);
};

export const validateAll = async ($LL: TranslationFunctions, value: ({{ name }}Input | null | undefined)[] | null | undefined) => {
	let errors: Record<number, Errors> = {};
	if (value) {
		for (let row = 0; row < value.length; row++) {
			const node = value[row];
			if (node) {
				const rowErrors = await validateRequired($LL, node);
				if (Object.keys(rowErrors).length > 0) {
					errors[row] = { iterms: rowErrors };
				}
			}
		}
		if (Object.keys(errors).length === 0) {
			for (let row = 0; row < value.length; row++) {
				const node = value[row];
				if (node) {
					const rowErrors = await validateErrors($LL, node);
					if (Object.keys(rowErrors).length > 0) {
						errors[row] = { iterms: rowErrors };
					}
				}
			}
		}
	}
	return new Promise(
		(
			resolve: (data: ({{ name }}Input | null | undefined)[] | null | undefined) => void,
			reject: (errors: Record<number, Errors>) => void
		) => {
			if (Object.keys(errors).length === 0) {
				resolve(value);
			} else {
				reject(errors);
			}
		}
	);
};

export const toRecords = ($LL: TranslationFunctions, value: ({{ name }}Input | null | undefined)[] | null | undefined, fieldArgs?: {{ name }}FieldsArgs | undefined, fieldsPatch?: {{ name }}Fields | undefined) => {
	if (fieldsPatch) {
		return value?.map(item =>
			Object.fromEntries(
				Object.entries(fieldsPatch)
					.flatMap(([fieldName, optionPatch]) => {
						const option = { ...{{ name | camelCase }}Fields?.[fieldName as keyof {{ name }}Fields], ...optionPatch };
						const fieldArg = fieldArgs?.[fieldName as keyof {{ name }}FieldsArgs];
						const title = option.title?.($LL, fieldArg) || fieldName;
						const fields = option.toFields?.();
						if (fields && option.toRecord) {
							return Object.entries(option.toRecord($LL, fields, title, item, fieldArg));
						}
						const entry: [string, string | null | undefined] = [title, option.toString?.($LL, item, fieldArg) || ''];
						return [entry];
					})
			)
		);
	}
	return value?.map(item =>
		Object.fromEntries(
			Object.entries({{ name | camelCase }}Fields)
				.flatMap(([fieldName, option]) => {
					const fieldArg = fieldArgs?.[fieldName as keyof {{ name }}FieldsArgs];
					const title = option.title?.($LL, fieldArg) || fieldName;
					const fields = option.toFields?.();
					if (fields && option.toRecord) {
						return Object.entries(option.toRecord($LL, fields, title, item, fieldArg));
					}
					const entry: [string, string | null | undefined] = [title, option.toString?.($LL, item, fieldArg) || ''];
					return [entry];
				})
		)
	);
}

export const toErrors = (errors: Record<number, Errors>, fieldsPatch?: {{ name }}Fields | undefined) => {
	if (fieldsPatch) {
		return Object.fromEntries(
			Object.entries(errors)
				.map(([row, errors]) =>
					[
						row,
						Object.entries(fieldsPatch)
							.flatMap(([fieldName, optionPatch]) => {
								const option = { ...{{ name | camelCase }}Fields?.[fieldName as keyof {{ name }}Fields], ...optionPatch };
								const fieldMessages = errors.iterms?.[fieldName]?.errors?.map(error => error.message);
								const fields = option.toFields?.();
								if (fields) {
									return Object.keys(fields)
										.map((subFieldName) =>
											[...(fieldMessages || []), ...(errors.iterms?.[fieldName]?.iterms?.[subFieldName]?.errors?.map(error => error.message) || [])]
										);
								}
								return [fieldMessages];
							})
					]
				)
		);
	}
	return Object.fromEntries(
		Object.entries(errors)
			.map(([row, errors]) =>
				[
					row,
					Object.entries({{ name | camelCase }}Fields)
						.flatMap(([fieldName, option]) => {
							const fieldMessages = errors.iterms?.[fieldName]?.errors?.map(error => error.message);
							const fields = option.toFields?.();
							if (fields) {
								return Object.keys(fields)
									.map((subFieldName) =>
										[...(fieldMessages || []), ...(errors.iterms?.[fieldName]?.iterms?.[subFieldName]?.errors?.map(error => error.message) || [])]
									);
							}
							return [fieldMessages];
						})
				]
			)
	);
}

export const fromRecords = ($LL: TranslationFunctions, records: Record<string, string | null | undefined>[] | undefined, fieldArgs?: {{ name }}FieldsArgs | undefined, fieldsPatch?: {{ name }}Fields | undefined) => {
	return records?.map(reocrd =>
		Object.fromEntries(
			Object.entries({{ name | camelCase }}Fields)
				.map(([fieldName, option]) => {
					const mergedOption = { ...option, ...fieldsPatch?.[fieldName as keyof {{ name }}Fields] };
					const fieldArg = fieldArgs?.[fieldName as keyof {{ name }}FieldsArgs];
					const title = mergedOption.title?.($LL, fieldArg) || fieldName;
					const fields = option.toFields?.();
					return [fieldName, mergedOption.fromRecord?.($LL, fields, title, reocrd, fieldArg)];
				})
		) as {{ name }}Input
	);
}