export type {{ name }}FieldsArgs = {
	{%- for field in fields %}
	{{ field.fieldName }}?: {} | undefined;
	{%- endfor %}
};

export type {{ name }}FieldsProps = {
	{%- for field in fields %}
	{{ field.fieldName }}?: {
		'tr'?: {} | undefined;
		'th'?: {} | undefined;
		'td'?: {} | undefined;
		'form-control'?: {} | undefined;
		{%- if field.isScalarType %}
