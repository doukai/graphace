import type { Errors } from '@graphace/commons';
import type { TabInfo } from '@graphace/ui';
import type { Option } from '@graphace/ui-graphql';
{%- for object in objects %}
{%- if object != name %}
import { {{ object | camelCase }}Fields, type {{ object }}Fields } from '~/{{ componentsPath }}/objects/{{ object | paramCase }}/{{ object }}Option';
{%- endif %}
{%- endfor %}
import type {
	{{ name }}Input,
	Query{{ name }}Args,
	Query{{ name }}ListArgs
{%- for object in objects %}
{%- if object != name %},
	{{ object }}Input
{%- endif %}
{%- endfor %}
{%- for enum in enums %},
	{{ enum }}
{%- endfor %}
} from '~/{{ schemaTypesPath }}';
import type { TranslationFunctions } from '$i18n/i18n-types';
{%- if useAuth %}
import { permissions } from '~/utils';
{%- endif %}

{%- if useAuth %}
const { auth } = permissions;
{%- endif %}

export const {{ name | camelCase }}Tabs: (($LL: TranslationFunctions, args?: Query{{ name }}ListArgs | undefined) => TabInfo[] | undefined) | undefined = undefined;

export const {{ name | camelCase }}Tab: ((args?: Query{{ name }}ListArgs | undefined) => string | undefined) | undefined = undefined;

export const {{ name | camelCase }}TabChange = async (tab: string, args: Query{{ name }}ListArgs, value?: ({{ name }}Input | null | undefined)[] | null | undefined) => {
	return new Promise(
		(
			resolve: (data: Query{{ name }}ListArgs) => void,
			reject: (errors: Record<number, Errors>) => void
		) => {
			resolve(args);
		}
	);
};

export const {{ name | camelCase }}FormTabs: (($LL: TranslationFunctions, args?: Query{{ name }}Args | undefined) => TabInfo[] | undefined) | undefined = undefined;

export const {{ name | camelCase }}FormTab: ((args?: Query{{ name }}Args | undefined) => string | undefined) | undefined = undefined;

export const {{ name | camelCase }}FormTabChange = async (tab: string, args: Query{{ name }}Args, value?: {{ name }}Input | null | undefined) => {
	return new Promise(
		(
			resolve: (data: Query{{ name }}Args) => void,
			reject: (errors: Record<string, Errors>) => void
		) => {
			resolve(args);
		}
	);
};

export type {{ name }}FieldsArgs = {
	{%- for field in fields %}
	{{ field.fieldName }}?: {} | undefined;
	{%- endfor %}
};

export type {{ name }}FieldsProps = {
	{%- for field in fields %}
	{{ field.fieldName }}?: {
		'tr'?: {} | undefined;
		'th'?: {} | undefined;
		'td'?: {} | undefined;
		'form-control'?: {} | undefined;
		{%- if field.isObjectType %}
		'table'?: {} | undefined;
		'form'?: {} | undefined;
		'combobox'?: {} | undefined;
		'dialog'?: {} | undefined;
		'link'?: {} | undefined;
		{%- else %}
		'input'?: {} | undefined;
		'select'?: {} | undefined;
		{%- endif %}
	} | undefined;
	{%- endfor %}
};

export type {{ name }}Fields = {
	{%- for field in fields %}
	{%- if field.isListType %}
	{{ field.fieldName }}?: Option<TranslationFunctions, {{ name }}Input, Query{{ name }}ListArgs, ({% if field.isObjectType %}{{ field.fieldTypeName }}Input{% elsif field.isEnumType %}{{ field.fieldTypeName }}{% else %}{{ field.tsTypeName }}{% endif %} | null | undefined)[] | null | undefined, {{ name }}FieldsArgs['{{ field.fieldName }}'], {{ name }}FieldsProps['{{ field.fieldName }}']>{% if field.isObjectType %} & { fields?: (value?: {{ name }}Input | undefined, fieldArg?: {{ name }}FieldsArgs['{{ field.fieldName }}']) => {{ field.fieldTypeName }}Fields }{% endif %} | undefined;
	{%- else %}
	{{ field.fieldName }}?: Option<TranslationFunctions, {{ name }}Input, Query{{ name }}ListArgs, {% if field.isObjectType %}{{ field.fieldTypeName }}Input{% elsif field.isEnumType %}{{ field.fieldTypeName }}{% else %}{{ field.tsTypeName }}{% endif %} | null | undefined, {{ name }}FieldsArgs['{{ field.fieldName }}'], {{ name }}FieldsProps['{{ field.fieldName }}']>{% if field.isObjectType %} & { fields?: (value?: {{ name }}Input | undefined, fieldArg?: {{ name }}FieldsArgs['{{ field.fieldName }}']) => {{ field.fieldTypeName }}Fields }{% endif %} | undefined;
	{%- endif %}
	{%- endfor %}
};

export const {{ name | camelCase }}Fields: {{ name }}Fields = {
	{%- for field in fields %}
	{{ field.fieldName }}: {
		readonly: (value, fieldArg) => {
			return {% if useAuth %}!auth('{{ name }}::{{ field.fieldName }}::WRITE'){% else %}false{% endif %};
		},
		disabled: (value, fieldArg) => {
			return {% if useAuth %}!auth('{{ name }}::{{ field.fieldName }}::WRITE'){% else %}false{% endif %};
		},
		hidden: (value, fieldArg) => {
			return {% if useAuth %}!auth('{{ name }}::{{ field.fieldName }}::READ'){% else %}false{% endif %};
		},
		hiddenCol: (args, tab, fieldArg) => {
			return {% if useAuth %}!auth('{{ name }}::{{ field.fieldName }}::READ'){% else %}false{% endif %};
		},
		required: (value) => {
			return {% if field.isNonNullType %}true{% else %}false{% endif %};
		},
		validate: async ($LL, value) => {
			return [];
		},
		onChange: async ($LL, fieldValue, value, fieldArg) => {
			return new Promise(
				(
					resolve: (data: {{ name }}Input | null | undefined) => void,
					reject: (errors: Errors) => void
				) => {
					resolve(value);
				}
			);
		},
		props: ($LL, value, fieldArg) => {
			return {};
		}{%- if field.isObjectType%},
		fields: (value, fieldArg) => {{ field.fieldTypeName | camelCase }}Fields
		{%- endif %}
	}{% if forloop.last == false %},{% endif %}
	{%- endfor %}
};

export const validateRequired = async ($LL: TranslationFunctions, value: {{ name }}Input | null | undefined) => {
	const errors: Record<string, Errors> = {};
	if (value) {
		{%- for field in fields %}
		if ({{ name | camelCase }}Fields?.{{ field.fieldName }}?.required?.(value) && value.{{ field.fieldName }} == null) {
			errors['{{ field.fieldName }}'] = { errors: [{ message: $LL.errors.jsonSchema.required() }] };
		}
		{%- endfor %}
	}
	return errors;
};

export const validateErrors = async ($LL: TranslationFunctions, value: {{ name }}Input | null | undefined) => {
	const errors: Record<string, Errors> = {};
	if (value) {
		{%- for field in fields %}
		const {{ field.fieldName }}Errors = await {{ name | camelCase }}Fields?.{{ field.fieldName }}?.validate?.($LL, value);
		if ({{ field.fieldName }}Errors && {{ field.fieldName }}Errors.length > 0) {
			errors['{{ field.fieldName }}'] = { errors: {{ field.fieldName }}Errors.map((message) => ({ message })) };
		}
		{%- endfor %}
	}
	return errors;
};

export const validate = async ($LL: TranslationFunctions, value: {{ name }}Input | null | undefined) => {
	let errors = await validateRequired($LL, value);
	if (Object.keys(errors).length === 0) {
		errors = await validateErrors($LL, value);
	}
	return new Promise(
		(
			resolve: (data: {{ name }}Input | null | undefined) => void,
			reject: (errors: Record<string, Errors>) => void
		) => {
			if (Object.keys(errors).length === 0) {
				resolve(value);
			} else {
				reject(errors);
			}
		}
	);
};

export const validateAll = async ($LL: TranslationFunctions, value: ({{ name }}Input | null | undefined)[] | null | undefined) => {
	let errors: Record<number, Errors> = {};
	if (value) {
		for (let row = 0; row < value.length; row++) {
			const node = value[row];
			if (node) {
				const rowErrors = await validateRequired($LL, node);
				if (Object.keys(rowErrors).length > 0) {
					errors[row] = { iterms: rowErrors };
				}
			}
		}
		if (Object.keys(errors).length === 0) {
			for (let row = 0; row < value.length; row++) {
				const node = value[row];
				if (node) {
					const rowErrors = await validateErrors($LL, node);
					if (Object.keys(rowErrors).length > 0) {
						errors[row] = { iterms: rowErrors };
					}
				}
			}
		}
	}
	return new Promise(
		(
			resolve: (data: ({{ name }}Input | null | undefined)[] | null | undefined) => void,
			reject: (errors: Record<number, Errors>) => void
		) => {
			if (Object.keys(errors).length === 0) {
				resolve(value);
			} else {
				reject(errors);
			}
		}
	);
};