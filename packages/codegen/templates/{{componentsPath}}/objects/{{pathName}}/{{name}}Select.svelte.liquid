<script lang="ts">
	import { createEventDispatcher } from 'svelte';
	import type { Errors } from '@graphace/commons';
	import { buildArguments } from '@graphace/graphql';
	import type { Option } from '@graphace/ui';
	import { ObjectSelect } from '@graphace/ui-graphql';
	import { createQueryNamed_{{ name | camelCase }}List_Store } from '~/{{ storesPath }}/query/query_{{ name | camelCase }}List_store';
	import { loadEvent } from '~/utils';
	import type { {{ name }}Input, Query{{ name }}ListArgs } from '~/{{ schemaTypesPath }}';

	export let id: string | undefined = undefined;
	export let name: string | undefined = undefined;
	export let value: {{ name }}Input | ({{ name }}Input | null | undefined)[] | null | undefined = undefined;
	export let args: Query{{ name }}ListArgs | undefined = undefined;
	export let first: number | undefined = 10;
	export let selected: Option | Option[] | undefined = undefined;
	export let errors: Errors | undefined = undefined;
	export let list: boolean | undefined = false;
	export let disabled = false;
	export let readonly = false;
	export let placeholder: string | null | undefined = undefined;
	let className: string | undefined = undefined;
	export { className as class };

	const dispatch = createEventDispatcher<{
		change: {
			value: {{ name }}Input | ({{ name }}Input | null | undefined)[] | null | undefined;
		};
	}>();

	const queryNamed_{{ name | camelCase }}List_Store = createQueryNamed_{{ name | camelCase }}List_Store($loadEvent);

	$: options =
		$queryNamed_{{ name | camelCase }}List_Store.response.data?.{{ name | camelCase }}List?.map((item) => ({
			label: item?.name,
			value: item?.{{ idName }},
			node: item
		})) || [];

	$: loading = $queryNamed_{{ name | camelCase }}List_Store.isFetching;

	$: if (Array.isArray(value)) {
		if (value.some((item) => !item?.name && item?.{{ idName }})){
			queryNamed_{{ name | camelCase }}List_Store
				.fetch({
					{{ idName }}: { opr: 'IN', arr: value?.map((item) => item?.{{ idName }}) }
				})
				.then((response) => {
					value = response.data?.{{ name | camelCase }}List;
				});
		} else {
			selected = value?.map((item) => ({
				label: item?.name,
				value: item?.{{ idName }},
				node: item
			}))
		}
	} else if (value) {
		if (!value.name && value.{{ idName }}) {
			queryNamed_{{ name | camelCase }}List_Store
				.fetch({ {{ idName }}: { opr: 'EQ', val: value.{{ idName }} } })
				.then((response) => {
					value = response.data?.{{ name | camelCase }}List?.[0];
				});
		} else {
			selected = { label: value?.name, value: value.{{ idName }}, node: value  };
		}
	} else {
		selected = undefined;
	}
</script>

<ObjectSelect
	{id}
	{name}
	bind:value={selected}
	bind:options
	{list}
	{disabled}
	{readonly}
	{placeholder}
	{errors}
	{loading}
	class={className}
	on:change={(e) => {
		if (Array.isArray(e.detail.value)) {
			value = e.detail.value.map((item) => ({
				id: item.value,
				name: item.label,
				...item.node
			}));
		} else if (e.detail.value && !Array.isArray(e.detail.value)) {
			value = { id: e.detail.value.value, name: e.detail.value.label, ...e.detail.value.node };
		} else {
			value = null;
		}
		dispatch('change', { value });
	{% raw %}}}{% endraw %}
	on:search={(e) => {
		if (e.detail.searchValue) {
			queryNamed_{{ name | camelCase }}List_Store.fetch(
				{ ...buildArguments(args), name: { opr: 'LK', val: `%${e.detail.searchValue}%` }, first }
			);
		} else {
			queryNamed_{{ name | camelCase }}List_Store.fetch({ ...buildArguments(args), first });
		}
	{% raw %}}}{% endraw %}
/>
