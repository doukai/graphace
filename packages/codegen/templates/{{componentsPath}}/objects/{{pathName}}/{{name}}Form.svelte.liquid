<script lang="ts">
	import { createEventDispatcher, getContext{% if groups != undefined and groups.length > 0 %}, type ComponentType{% endif %} } from 'svelte';
	import type { Readable } from 'svelte/store';
	import type { Errors } from '@graphace/commons';
	import { Buttons, Empty, Form, ErrorLabels, FormControl, Label, Loading{% if groups != undefined and groups.length > 0 %}, Wrapper{% endif %}, to } from '@graphace/ui';
	import { {% for scalar in scalars %}{{ scalar }}Input, {% endfor %}{% if hasFileField %}FileInput, {% endif %}ObjectLink } from '@graphace/ui-graphql';
	{%- for enum in enums %}
	import {{ enum }}Input from '~/{{ componentsPath }}/enums/{{ enum | paramCase }}/{{ enum }}Input.svelte';
	{%- endfor %}
	{%- for select in selects %}
	import {{ select }}Select from '~/{{ componentsPath }}/objects/{{ select | paramCase }}/{{ select }}Select.svelte';
	{%- endfor %}
	{%- for table in tables %}
	import {{ table }}Editable from '~/{{ componentsPath }}/objects/{{ table | paramCase }}/{{ table }}Editable.svelte';
	{%- endfor %}
	{%- for dialog in nonSelects %}
	import {{ dialog }}TableDialog from '~/{{ componentsPath }}/objects/{{ dialog | paramCase }}/{{ dialog }}TableDialog.svelte';
	{%- endfor %}
	import {
		{{ name | camelCase }}Fields,
		type {{ name }}Fields,
		validate
	} from '~/{{ componentsPath }}/objects/{{ name | paramCase }}/{{ name }}Option';
	import type { {{ name }}Input } from '~/{{ schemaTypesPath }}';
	import type { TranslationFunctions } from '$i18n/i18n-types';
	{%- if tables and tables.length > 0 %}
	import { locale } from '~/lib/i18n/i18n-svelte';
	{%- endif %}
	
	export let value: {{ name }}Input | null | undefined = undefined;
	export let isFetching: boolean = false;
	export let isMutating: boolean = false;
	export let errors: Record<string, Errors> = {};
	export let showRemoveButton: boolean = false;
	export let showUnbindButton: boolean = false;
	export let showSaveButton: boolean = false;
	export let showSelectButton: boolean = false;
	export let showBackButton: boolean = false;
	export let title: string | undefined = undefined;
	let className: string | undefined =
		'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-2 overflow-x-hidden overflow-y-auto';
	export { className as class };
	export let fields: {{ name }}Fields | undefined = {{ name | camelCase }}Fields;
	export let fieldsArgs: Record<string, any> | undefined = undefined;
	{%- if groups != undefined and groups.length > 0 %}
	export let wrapper: Record<string, ComponentType> = {
		{%- for group in groups %}
		'{{ group.name }}': Wrapper{% if forloop.last == false %},{% endif %}
		{%- endfor %}
	};
	export let wrapperProps: Record<string, Record<string, any>> = {
		{%- for group in groups %}
		{%- if forloop.last %}
		'{{ group.name }}': { last: true }
		{%- endif %}
		{%- endfor %}
	};
	{%- endif %}

	const LL = getContext<Readable<TranslationFunctions>>('LL');

	const dispatch = createEventDispatcher<{
		remove: { value: {{ name }}Input | null | undefined };
		unbind: { value: {{ name }}Input | null | undefined };
		save: { value: {{ name }}Input | null | undefined };
		goto: { path: string; name: string | undefined };
		back: {};
	}>();
</script>

<div class="flex justify-between">
	<slot name="title">
		<span class="text-xl font-semibold self-center">
			{#if title}
				{title}
			{:else}
				{$LL.graphql.objects.{{ name }}.name()}
			{/if}
		</span>
	</slot>
	<Buttons
		{showRemoveButton}
		{showUnbindButton}
		{showSaveButton}
		{showSelectButton}
		{showBackButton}
		loading={isMutating}
		on:save={(e) => validate($LL, value).then(() => dispatch('save', { value }))}
		on:remove={(e) => dispatch('remove', { value })}
		on:unbind={(e) => dispatch('unbind', { value })}
		on:back
	>
		<slot />
	</Buttons>
</div>
<div class="divider my-0" />
<Form class={className}>
	{#if isFetching}
		<Loading />
	{:else if value}
		{%- if groups != undefined and groups.length > 0 %}
		{%- for group in groups %}
		<svelte:component this={wrapper['{{ group.name }}']} {...wrapperProps['{{ group.name }}']}>
			{%- for field in group.fields %}
			<slot name="{{ field.fieldName }}" {value} {errors} {fields}>
				{#if !fields?.{{ field.fieldName }}?.hidden?.(value, fieldsArgs?.{{ field.fieldName }})}
					{%- if field.isTable %}
					<div class="col-span-full">
						<{{ field.fieldTypeName }}Editable
							title={$LL.graphql.objects.{{ name }}.fields.{{ field.fieldName }}.name()}
							fields={fields?.{{ field.fieldName }}?.fields?.(value, fieldsArgs?.{{ field.fieldName }})}
							showCreateDialog
							showEditDialog
							showRemoveButton
							bind:value={value.{{ field.fieldName }}}
							errors={errors.{{ field.fieldName }}?.iterms}
							{isFetching}
							{isMutating}
							on:remove={(e) => {
								if (e.detail.row !== undefined) {
									value.{{ field.fieldName }} = [...(value.{{ field.fieldName }}?.splice(e.detail.row + 1, 1) || [])];
								}
							{% raw %}}}{% endraw %}
							on:goto={(e) => to(`/${$locale}/{{ field.fieldTypeName | paramCase }}/${e.detail.path}`)}
							{...fields?.{{ field.fieldName }}?.props?.($LL, value, fieldsArgs?.{{ field.fieldName }})?.['table']}
						/>
						<ErrorLabels errors={errors.{{ field.fieldName }}} />
					</div>
					{%- else %}
					<FormControl let:id {...fields?.{{ field.fieldName }}?.props?.($LL, value, fieldsArgs?.{{ field.fieldName }})?.['form-control']}>
						<Label
							{id}
							text={$LL.graphql.objects.{{ name }}.fields.{{ field.fieldName }}.name()}
							required={fields?.{{ field.fieldName }}?.required?.(value)}
						/>
						{%- if field.isScalarType or field.isEnumType or field.isFile %}
						<{{ field.fieldTypeName }}Input
							{id}
							name="{{ field.fieldName }}"
							bind:value={value.{{ field.fieldName }}}
							errors={errors.{{ field.fieldName }}}
							readonly={fields?.{{ field.fieldName }}?.readonly?.(value, fieldsArgs?.{{ field.fieldName }})}
							disabled={fields?.{{ field.fieldName }}?.disabled?.(value, fieldsArgs?.{{ field.fieldName }})}
							on:change={(e) => {
								{%- if field.isListType %}
								if (Array.isArray(e.detail.value) || e.detail.value == null) {
									fields?.{{ field.fieldName }}
										?.onChange?.($LL, e.detail.value, value, fieldsArgs?.{{ field.fieldName }})
										.then((next) => (value = next))
										.catch((e) => (errors = { ...errors, {{ field.fieldName }}: e }));
								}
								{%- else %}
								if (!Array.isArray(e.detail.value) || e.detail.value == null) {
									fields?.{{ field.fieldName }}
										?.onChange?.($LL, e.detail.value, value, fieldsArgs?.{{ field.fieldName }})
										.then((next) => (value = next))
										.catch((e) => (errors = { ...errors, {{ field.fieldName }}: e }));
								}
								{%- endif %}
							}}
							{%- if field.isListType %}
							list
							{%- endif %}
							{%- if field.fieldTypeName == 'File' %}
							on:upload
							{%- endif %}
							{%- if field.isScalarType %}
							{...fields?.{{ field.fieldName }}?.props?.($LL, value, fieldsArgs?.{{ field.fieldName }})?.['input']}
							{%- else %}
							{...fields?.{{ field.fieldName }}?.props?.($LL, value, fieldsArgs?.{{ field.fieldName }})?.['select']}
							{%- endif %}
						/>
						{%- elsif field.isSelect %}
						<{{ field.fieldTypeName }}Select
							{id}
							name="{{ field.fieldName }}"
							bind:value={value.{{ field.fieldName }}}
							errors={errors.{{ field.fieldName }}}
							readonly={fields?.{{ field.fieldName }}?.readonly?.(value, fieldsArgs?.{{ field.fieldName }})}
							disabled={fields?.{{ field.fieldName }}?.disabled?.(value, fieldsArgs?.{{ field.fieldName }})}
							on:change={(e) => {
								{%- if field.isListType %}
								if (Array.isArray(e.detail.value) || e.detail.value == null) {
									fields?.{{ field.fieldName }}
										?.onChange?.($LL, e.detail.value, value, fieldsArgs?.{{ field.fieldName }})
										.then((next) => (value = next))
										.catch((e) => (errors = { ...errors, {{ field.fieldName }}: e }));
								}
								{%- else %}
								if (!Array.isArray(e.detail.value) || e.detail.value == null) {
									fields?.{{ field.fieldName }}
										?.onChange?.($LL, e.detail.value, value, fieldsArgs?.{{ field.fieldName }})
										.then((next) => (value = next))
										.catch((e) => (errors = { ...errors, {{ field.fieldName }}: e }));
								}
								{%- endif %}
							}}
							{%- if field.isListType %}
							list
							{%- endif %}
							{...fields?.{{ field.fieldName }}?.props?.($LL, value, fieldsArgs?.{{ field.fieldName }})?.['combobox']}
						/>
						{%- else %}
						{#if value.{{idName}}}
							<ObjectLink
								bind:value={value.{{ field.fieldName }}}
								{%- if field.textFieldName %}
								textFieldName="{{field.textFieldName}}"
								{%- elsif field.isNamed %}
								textFieldName="name"
								{%- endif %}
								path={`${value.{{ idName }}}/{{ field.fieldName | paramCase }}`}
								on:goto
								{...fields?.{{ field.fieldName }}?.props?.($LL, value, fieldsArgs?.{{ field.fieldName }})?.['link']}
							/>
						{:else}
							<{{ field.fieldTypeName }}TableDialog
								bind:value={value.{{ field.fieldName }}}
								{%- if field.textFieldName %}
								textFieldName="{{field.textFieldName}}"
								{%- elsif field.isNamed %}
								textFieldName="name"
								{%- endif %}
								{%- if field.isListType == false %}
								singleChoice
								{%- endif %}
								class="btn-link"
								readonly={fields?.{{ field.fieldName }}?.readonly?.(value, fieldsArgs?.{{ field.fieldName }})}
								disabled={fields?.{{ field.fieldName }}?.disabled?.(value, fieldsArgs?.{{ field.fieldName }})}
							on:change={(e) => {
								{%- if field.isListType %}
								if (Array.isArray(e.detail.value) || e.detail.value == null) {
									fields?.{{ field.fieldName }}
										?.onChange?.($LL, e.detail.value, value, fieldsArgs?.{{ field.fieldName }})
										.then((next) => (value = next))
										.catch((e) => (errors = { ...errors, {{ field.fieldName }}: e }));
								}
								{%- else %}
								if (!Array.isArray(e.detail.value) || e.detail.value == null) {
									fields?.{{ field.fieldName }}
										?.onChange?.($LL, e.detail.value, value, fieldsArgs?.{{ field.fieldName }})
										.then((next) => (value = next))
										.catch((e) => (errors = { ...errors, {{ field.fieldName }}: e }));
								}
								{%- endif %}
							}}
								{...fields?.{{ field.fieldName }}?.props?.($LL, value, fieldsArgs?.{{ field.fieldName }})?.['dialog']}
							/>
						{/if}
						<ErrorLabels {id} errors={errors.{{ field.fieldName }}} />
						{%- endif %}
					</FormControl>
					{%- endif %}
				{/if}
			</slot>
			{%- endfor %}
		</svelte:component>
		{%- endfor %}
		{%- else %}
		{%- for field in fields %}
		<slot name="{{ field.fieldName }}" {value} {errors} {fields}>
			{#if !fields?.{{ field.fieldName }}?.hidden?.(value, fieldsArgs?.{{ field.fieldName }})}
				{%- if field.isTable %}
				<div class="col-span-full">
					<{{ field.fieldTypeName }}Editable
						title={$LL.graphql.objects.{{ name }}.fields.{{ field.fieldName }}.name()}
						fields={fields?.{{ field.fieldName }}?.fields?.(value, fieldsArgs?.{{ field.fieldName }})}
						showCreateDialog
						showEditDialog
						showRemoveButton
						bind:value={value.{{ field.fieldName }}}
						errors={errors.{{ field.fieldName }}?.iterms}
						{isFetching}
						{isMutating}
						on:remove={(e) => {
							if (e.detail.row !== undefined) {
								value.{{ field.fieldName }} = [...(value.{{ field.fieldName }}?.splice(e.detail.row + 1, 1) || [])];
							}
						{% raw %}}}{% endraw %}
						on:goto={(e) => to(`/${$locale}/{{ field.fieldTypeName | paramCase }}/${e.detail.path}`)}
						{...fields?.{{ field.fieldName }}?.props?.($LL, value, fieldsArgs?.{{ field.fieldName }})?.['table']}
					/>
					<ErrorLabels errors={errors.{{ field.fieldName }}} />
				</div>
				{%- else %}
				<FormControl let:id {...fields?.{{ field.fieldName }}?.props?.($LL, value, fieldsArgs?.{{ field.fieldName }})?.['form-control']}>
					<Label
						{id}
						text={$LL.graphql.objects.{{ name }}.fields.{{ field.fieldName }}.name()}
						required={fields?.{{ field.fieldName }}?.required?.(value)}
					/>
					{%- if field.isScalarType or field.isEnumType or field.isFile %}
					<{{ field.fieldTypeName }}Input
						{id}
						name="{{ field.fieldName }}"
						bind:value={value.{{ field.fieldName }}}
						errors={errors.{{ field.fieldName }}}
						readonly={fields?.{{ field.fieldName }}?.readonly?.(value, fieldsArgs?.{{ field.fieldName }})}
						disabled={fields?.{{ field.fieldName }}?.disabled?.(value, fieldsArgs?.{{ field.fieldName }})}
						on:change={(e) => {
							{%- if field.isListType %}
							if (Array.isArray(e.detail.value) || e.detail.value == null) {
								fields?.{{ field.fieldName }}
									?.onChange?.($LL, e.detail.value, value, fieldsArgs?.{{ field.fieldName }})
									.then((next) => (value = next))
									.catch((e) => (errors = { ...errors, {{ field.fieldName }}: e }));
							}
							{%- else %}
							if (!Array.isArray(e.detail.value) || e.detail.value == null) {
								fields?.{{ field.fieldName }}
									?.onChange?.($LL, e.detail.value, value, fieldsArgs?.{{ field.fieldName }})
									.then((next) => (value = next))
									.catch((e) => (errors = { ...errors, {{ field.fieldName }}: e }));
							}
							{%- endif %}
						}}
						{%- if field.isListType %}
						list
						{%- endif %}
						{%- if field.fieldTypeName == 'File' %}
						on:upload
						{%- endif %}
						{%- if field.isScalarType %}
						{...fields?.{{ field.fieldName }}?.props?.($LL, value, fieldsArgs?.{{ field.fieldName }})?.['input']}
						{%- else %}
						{...fields?.{{ field.fieldName }}?.props?.($LL, value, fieldsArgs?.{{ field.fieldName }})?.['select']}
						{%- endif %}
					/>
					{%- elsif field.isSelect %}
					<{{ field.fieldTypeName }}Select
						{id}
						name="{{ field.fieldName }}"
						bind:value={value.{{ field.fieldName }}}
						errors={errors.{{ field.fieldName }}}
						readonly={fields?.{{ field.fieldName }}?.readonly?.(value, fieldsArgs?.{{ field.fieldName }})}
						disabled={fields?.{{ field.fieldName }}?.disabled?.(value, fieldsArgs?.{{ field.fieldName }})}
						on:change={(e) => {
							{%- if field.isListType %}
							if (Array.isArray(e.detail.value) || e.detail.value == null) {
								fields?.{{ field.fieldName }}
									?.onChange?.($LL, e.detail.value, value, fieldsArgs?.{{ field.fieldName }})
									.then((next) => (value = next))
									.catch((e) => (errors = { ...errors, {{ field.fieldName }}: e }));
							}
							{%- else %}
							if (!Array.isArray(e.detail.value) || e.detail.value == null) {
								fields?.{{ field.fieldName }}
									?.onChange?.($LL, e.detail.value, value, fieldsArgs?.{{ field.fieldName }})
									.then((next) => (value = next))
									.catch((e) => (errors = { ...errors, {{ field.fieldName }}: e }));
							}
							{%- endif %}
						}}
						{%- if field.isListType %}
						list
						{%- endif %}
						{...fields?.{{ field.fieldName }}?.props?.($LL, value, fieldsArgs?.{{ field.fieldName }})?.['combobox']}
					/>
					{%- else %}
					{#if value.{{idName}}}
						<ObjectLink
							bind:value={value.{{ field.fieldName }}}
							{%- if field.textFieldName %}
							textFieldName="{{field.textFieldName}}"
							{%- elsif field.isNamed %}
							textFieldName="name"
							{%- endif %}
							path={`${value.{{ idName }}}/{{ field.fieldName | paramCase }}`}
							on:goto
							{...fields?.{{ field.fieldName }}?.props?.($LL, value, fieldsArgs?.{{ field.fieldName }})?.['link']}
						/>
					{:else}
						<{{ field.fieldTypeName }}TableDialog
							bind:value={value.{{ field.fieldName }}}
							{%- if field.textFieldName %}
							textFieldName="{{field.textFieldName}}"
							{%- elsif field.isNamed %}
							textFieldName="name"
							{%- endif %}
							{%- if field.isListType == false %}
							singleChoice
							{%- endif %}
							class="btn-link"
							readonly={fields?.{{ field.fieldName }}?.readonly?.(value, fieldsArgs?.{{ field.fieldName }})}
							disabled={fields?.{{ field.fieldName }}?.disabled?.(value, fieldsArgs?.{{ field.fieldName }})}
							on:select={(e) => {
								{%- if field.isListType %}
								if (Array.isArray(e.detail.value) || e.detail.value == null) {
									fields?.{{ field.fieldName }}
										?.onChange?.($LL, e.detail.value, value, fieldsArgs?.{{ field.fieldName }})
										.then((next) => (value = next))
										.catch((e) => (errors = { ...errors, {{ field.fieldName }}: e }));
								}
								{%- else %}
								if (!Array.isArray(e.detail.value) || e.detail.value == null) {
									fields?.{{ field.fieldName }}
										?.onChange?.($LL, e.detail.value, value, fieldsArgs?.{{ field.fieldName }})
										.then((next) => (value = next))
										.catch((e) => (errors = { ...errors, {{ field.fieldName }}: e }));
								}
								{%- endif %}
							}}
							{...fields?.{{ field.fieldName }}?.props?.($LL, value, fieldsArgs?.{{ field.fieldName }})?.['dialog']}
						/>
					{/if}
					<ErrorLabels {id} errors={errors.{{ field.fieldName }}} />
					{%- endif %}
				</FormControl>
				{%- endif %}
			{/if}
		</slot>
		{%- endfor %}
		{%- endif %}
	{:else}
		<div class="col-span-full">
			<Empty />
		</div>
	{/if}
</Form>
<div class="divider my-0" />
<div class="flex justify-end">
	<Buttons
		{showRemoveButton}
		{showUnbindButton}
		{showSaveButton}
		{showSelectButton}
		{showBackButton}
		loading={isMutating}
		on:save={(e) => validate($LL, value).then(() => dispatch('save', { value }))}
		on:remove={(e) => dispatch('remove', { value })}
		on:unbind={(e) => dispatch('unbind', { value })}
		on:back
	/>
</div>